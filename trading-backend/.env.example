# Interactive Brokers
IB_HOST=ibgateway
IB_PORT=4002
IB_CLIENT_ID=1
IB_USERNAME=your_ib_username
IB_PASSWORD=your_ib_password
IB_TRADING_MODE=live

# Database
DATABASE_URL=postgresql+asyncpg://trading:changeme@postgres:5432/trading
DB_USER=trading
DB_PASSWORD=changeme

# API Security
API_KEY=generate-a-strong-random-key-here
ALLOWED_ORIGINS=https://day-trading.pages.dev

# Trading Parameters (defaults, can be changed via API)
STARTING_CAPITAL=100.0
MAX_ORDER_SIZE=20.0
MAX_RISK_PER_TRADE=0.02
MAX_DAILY_LOSS=0.05
MAX_OPEN_POSITIONS=5

# Logging
LOG_LEVEL=INFO
